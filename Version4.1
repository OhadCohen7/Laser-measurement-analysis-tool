# ── CSV parser ─────────────────────────────────────────────────────────────────

def parse_csv(filepath):
    df = pd.read_csv(filepath, header=0)
    df.columns = [str(c).strip() for c in df.columns]
    target_col = df.columns[1]
    run_cols   = df.columns[2:]

    run_labels = []
    for i, _ in enumerate(run_cols):
        run_num   = i // 2 + 1
        direction = "+" if i % 2 == 0 else "\u2212"
        run_labels.append(f"Run{run_num}{direction}")

    data = {}
    for _, row in df.iterrows():
        tgt  = row[target_col]
        vals = pd.to_numeric(row[run_cols], errors="coerce").values
        if tgt not in data:
            data[tgt] = []
        data[tgt].append(vals)

    for tgt in data:
        arr = np.array(data[tgt], dtype=float)
        data[tgt] = np.nanmean(arr, axis=0)

    def sort_key(x):
        try:    return float(x)
        except: return 0

    targets = sorted(data.keys(), key=sort_key)
    return targets, list(run_labels), data


